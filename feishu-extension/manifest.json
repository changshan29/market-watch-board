{
  "manifest_version": 3,
  "name": "飞书消息采集",
  "version": "1.0",
  "description": "从飞书网页版群聊采集消息，推送到看板服务器",
  "permissions": ["storage", "alarms", "scripting", "tabs"],
  "host_permissions": [
    "https://*.feishu.cn/*",
    "https://market-watch-board-production.up.railway.app/*",
    "http://localhost:3220/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.feishu.cn/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "飞书消息采集"
  }
}
